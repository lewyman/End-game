{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/educator", "destination": "/api?path=/educator" },
    { "source": "/api/drugs", "destination": "/api?path=/drugs" },
    { "source": "/api/drugs/:slug", "destination": "/api?path=/drugs/:slug" },
    { "source": "/api/admin/drugs", "destination": "/api?path=/admin/drugs" },
    { "source": "/api/admin/drugs/:path*", "destination": "/api?path=/admin/drugs/:path*" },
    { "source": "/api/login", "destination": "/api?path=/login" },
    { "source": "/api/signup", "destination": "/api?path=/signup" },
    { "source": "/api/oauth-login", "destination": "/api?path=/oauth-login" },
    { "source": "/api/health", "destination": "/api?path=/health" },
    { "source": "/api/songs", "destination": "/api?path=/songs" },
    { "source": "/api/songs/:slug", "destination": "/api?path=/songs/:slug" },
    { "source": "/api/playlists", "destination": "/api?path=/playlists" },
    { "source": "/api/admin/songs", "destination": "/api?path=/admin/songs" },
    { "source": "/api/admin/songs/:slug", "destination": "/api?path=/admin/songs/:slug" },
    { "source": "/drugs/:path*", "destination": "/" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
